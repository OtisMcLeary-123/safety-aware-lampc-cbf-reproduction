    "position_lower": [-3.0, -3.0, 0.0],
    "yaw_bounds_pi_fraction": 0.55,
    "linear_input_limit": 0.2,
    "yaw_input_limit_pi": 1.0
  },
  "unpublished_reconstructions": [

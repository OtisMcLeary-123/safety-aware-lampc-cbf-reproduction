{
  "profile_name": "paper_fidelity_v3_eq18_static",
  "created": "2026-07-17",
  "supersedes": "configs/paper_fidelity_v2_eq18_static.json",
  "purpose": "Paper-faithful controller profile: printed eq. (18) dynamics via paper_state (v2 used paper_increment under a misreading of A's lower-right block; see registry 1.1 correction history), static horizon obstacle assumption, reconstructed terminal safe set, library-default IPOPT.",
  "paper_doi": "10.1109/ACCESS.2026.3664145",
  "deviation_registry": "docs/PAPER_FIDELITY_DEVIATION_REGISTRY.md",
  "smooth_dynamic_config": {

    "formal_safety_filter_enabled": false,
    "terminal_safe_set_enabled": true,
    "ipopt_profile": "reference_defaults",
    "cbf_constraint_scope": "horizon",
    "solver_fallback_mode": "zero",
    "sensor_period": 0.67,
    "measurement_noise_sigma": 0.005,
